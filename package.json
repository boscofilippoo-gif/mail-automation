{
  "name": "mail-automation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/server"
  ],
  "scripts": {
    "postinstall": "node scripts/render-postinstall.cjs",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace apps/server",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/server && npm run build --workspace apps/web",
    "start": "npm run start --workspace apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
