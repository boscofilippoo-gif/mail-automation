# ─────────────────────────────────────────────────────────────
# Mail Automation — variabili d'ambiente
# Copia questo file in `.env` e compila i valori reali.
# ─────────────────────────────────────────────────────────────

# Porta del backend Express
PORT=4000

# URL del frontend (per CORS e redirect post-login)
WEB_ORIGIN=http://localhost:5273

# ── Google OAuth (Google Cloud Console → API & Services → Credentials) ──
# Tipo credenziale: "OAuth client ID" → "Web application"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Deve combaciare ESATTAMENTE con un "Authorized redirect URI" nel client OAuth
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ── Anthropic ──
ANTHROPIC_API_KEY=
# Modello usato per l'estrazione dei dati dalle mail
ANTHROPIC_MODEL=claude-opus-4-8

# ── Sicurezza ──
# Segreto per firmare i cookie di sessione (stringa lunga e casuale)
SESSION_SECRET=changeme-genera-una-stringa-lunga-e-casuale
# Chiave per cifrare i token OAuth a riposo: 32 byte in esadecimale (64 caratteri hex).
# Generala con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_KEY=
